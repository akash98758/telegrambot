# Telegram Bot Token from BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Telegram Channel ID (e.g., -1001234567890 or @yourchannelusername)
CHANNEL_ID=YOUR_TELEGRAM_CHANNEL_ID

# Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Comma-separated list of RSS feed URLs
# e.g., RSS_FEED_URLS=https://example.com/feed1.xml,https://another.example.com/feed2.xml
RSS_FEED_URLS=URL_1,URL_2

# Interval in hours for posting jobs
JOB_POSTING_INTERVAL_HOURS=1
